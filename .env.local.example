# Supabase — find these in your project's API settings
# https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — server-only, bypasses RLS. Used for admin operations.
# NEVER expose this to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Resend — email notifications for order flow
# https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_EMAIL=orders@<your-verified-domain.com>
ADMIN_NOTIFY_EMAIL=<admin-email@example.com>
